{
  "name": "@tomsawyerlabs/ui",
  "version": "0.2.0",
  "description": "Tom Sawyer Labs shared design system: interactive gradient background, base styling, logo, and layout shell.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TomSawyerLabs/ui.git"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "hooks": "lefthook install",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.43.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
